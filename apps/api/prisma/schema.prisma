generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum CertificateTrustMode {
  STRICT
  CUSTOM_CA
  ALLOW_SELF_SIGNED
}

enum AppLoginMode {
  PIHOLE_MASTER
  YAPD_PASSWORD
}

enum InstanceSessionAuthSource {
  HUMAN_MASTER
  STORED_SECRET
}

enum SyncOperationKey {
  BLOCKING
}

enum SyncJobStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILURE
}

enum SyncAttemptStatus {
  SUCCESS
  FAILURE
  NOOP
  SKIPPED
}

enum NotificationState {
  ACTIVE
  RESOLVED
}

model AppConfig {
  id                         String       @id @default("singleton")
  loginMode                  AppLoginMode @default(PIHOLE_MASTER)
  passwordHash               String?
  timeZone                   String       @default("UTC")
  webPushVapidPublicKey      String?
  webPushVapidPrivateKeyEncrypted String?
  webPushVapidSubject        String?
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
}

model Instance {
  id               String                     @id @default(cuid())
  name             String
  baseUrl          String
  isBaseline       Boolean                    @default(false)
  syncEnabled      Boolean                    @default(true)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  lastValidatedAt  DateTime?
  lastKnownVersion String?
  secret           InstanceSecret?
  certificateTrust InstanceCertificateTrust?
  session          InstanceSession?
  syncAttempts     SyncAttempt[]
  notifications    Notification[]
  groupMemberships ClientGroupMembership[]
}

model InstanceSecret {
  id                String   @id @default(cuid())
  instanceId        String   @unique
  encryptedPassword String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  instance          Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model InstanceCertificateTrust {
  id                String               @id @default(cuid())
  instanceId        String               @unique
  mode              CertificateTrustMode @default(STRICT)
  certificatePem    String?
  fingerprintSha256 String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  instance          Instance             @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model InstanceSession {
  id               String                    @id @default(cuid())
  instanceId       String                    @unique
  encryptedSid     String
  encryptedCsrf    String
  piholeSessionId  Int?
  loginAt          DateTime?
  lastActiveAt     DateTime?
  validUntil       DateTime?
  authSource       InstanceSessionAuthSource
  lastErrorKind    String?
  lastErrorMessage String?
  lastErrorAt      DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  instance         Instance                  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  actorType  String
  actorLabel String?
  ipAddress  String?
  targetType String?
  targetId   String?
  result     String
  details    Json?
  createdAt  DateTime @default(now())
}

model ClientDevice {
  id               String                  @id @default(cuid())
  hwaddr           String                  @unique
  alias            String?
  macVendor        String?
  ips              String[]                @default([])
  tags             String[]                @default([])
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  groupMemberships ClientGroupMembership[]
}

model ClientGroup {
  id          Int                     @id
  name        String                  @unique
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  memberships ClientGroupMembership[]
}

model ClientGroupMembership {
  groupId        Int
  instanceId     String
  clientKey      String
  clientDeviceId String?
  rawClientValue String?
  rawClientName  String?
  resolvedIps    String[]   @default([])
  lastSyncedAt   DateTime
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  group          ClientGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  instance       Instance    @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  clientDevice   ClientDevice? @relation(fields: [clientDeviceId], references: [id], onDelete: SetNull)

  @@id([groupId, instanceId, clientKey])
  @@index([instanceId, groupId])
  @@index([clientDeviceId])
}

model SyncOperationPreset {
  id           String           @id @default(cuid())
  operationKey SyncOperationKey
  name         String           @default("Saved preset")
  timerSeconds Int
  sortOrder    Int              @default(1000)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([operationKey, sortOrder])
}

model SyncJob {
  id              String           @id @default(cuid())
  operationKey    SyncOperationKey
  scope           String
  requestedConfig Json
  status          SyncJobStatus
  summary         Json?
  startedAt       DateTime         @default(now())
  finishedAt      DateTime?
  attempts        SyncAttempt[]
}

model SyncAttempt {
  id             String            @id @default(cuid())
  syncJobId      String
  instanceId     String
  attemptNumber  Int
  status         SyncAttemptStatus
  message        String?
  requestPayload Json?
  responsePayload Json?
  createdAt      DateTime          @default(now())
  syncJob        SyncJob           @relation(fields: [syncJobId], references: [id], onDelete: Cascade)
  instance       Instance          @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([syncJobId, instanceId, attemptNumber])
}

model ManagedList {
  id        String   @id @default(cuid())
  address   String
  comment   String?
  type      String   @default("block")
  groups    Int[]    @default([0])
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([address, type])
}

model ManagedDomain {
  id        String   @id @default(cuid())
  domain    String
  type      String   // allow | deny
  kind      String   // exact | regex
  comment   String?
  groups    Int[]    @default([0])
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([domain, type, kind])
}

model RegexFilter {
  id        String   @id @default(cuid())
  name      String   @unique
  pattern   String   @unique
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id                   String            @id @default(cuid())
  source               String
  type                 String
  instanceId           String?
  instanceNameSnapshot String?
  message              String
  metadata             Json?
  state                NotificationState @default(ACTIVE)
  isRead               Boolean           @default(false)
  readAt               DateTime?
  hiddenAt             DateTime?
  resolvedAt           DateTime?
  firstSeenAt          DateTime          @default(now())
  lastSeenAt           DateTime          @default(now())
  occurredAt           DateTime          @default(now())
  occurrenceCount      Int               @default(1)
  sourceFingerprint    String
  sourceExternalId     String?
  deleteRequestedAt    DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  instance             Instance?         @relation(fields: [instanceId], references: [id], onDelete: SetNull)

  @@index([sourceFingerprint])
  @@index([hiddenAt, resolvedAt, occurredAt])
  @@index([createdAt])
}

model PushSubscription {
  id            String   @id @default(cuid())
  endpoint      String   @unique
  p256dh        String
  auth          String
  userAgent     String?
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  failureCount  Int      @default(0)
  disabledAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([disabledAt])
}
