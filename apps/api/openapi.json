                            "type": "string"
                          },
                          "instanceName": {
                            "type": "string"
                          },
                          "blocking": {
                            "type": "string",
                            "enum": ["enabled", "disabled"]
                          },
                          "timerSeconds": {
                            "type": "number",
                            "nullable": true
                          }
                        },
                        "required": ["instanceId", "instanceName", "blocking", "timerSeconds"]
                      }
                    },
                    "noopInstances": {
