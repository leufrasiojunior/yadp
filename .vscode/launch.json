{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "YAPD Back",
      "type": "pwa-node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "cwd": "${workspaceFolder}/apps/api",
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "yapd:dev:api:debug"
    },
    {
      "name": "YAPD Front",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/apps/web",
      "preLaunchTask": "yapd:dev:web"
    }
  ],
  "compounds": [
    {
      "name": "YAPD Full Stack",
      "configurations": ["YAPD Back", "YAPD Front"],
      "stopAll": true
    }
  ]
}
