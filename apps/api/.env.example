NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yapd?schema=public
SESSION_COOKIE_NAME=yapd_session
SESSION_SECRET=replace-this-session-secret
APP_ENCRYPTION_KEY=replace-this-encryption-key
COOKIE_SECURE=false
SWAGGER_ENABLED=true
SKIP_DB_CONNECT=false
