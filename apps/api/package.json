{
  "name": "@yapd/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run prisma:generate && npm run db:push",
    "dev": "node --watch --import tsx src/main.ts",
    "debug": "node --inspect=9229 --watch --import tsx src/main.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/main.js",
    "generate:client": "npx tsx --tsconfig tsconfig.json src/scripts/generate-openapi.ts",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "db:push": "prisma db push --config prisma.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "undici": "^7.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/pg": "^8.15.6",
    "dotenv": "^17.2.3",
    "prisma": "^7.5.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16"
  }
}
