{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "yapd:dev:api:debug",
      "type": "shell",
      "command": "npm run debug",
      "options": {
        "cwd": "${workspaceFolder}/apps/api"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "."
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "YAPD API listening on http://127\\.0\\.0\\.1:3001/api.*"
        }
      },
      "presentation": {
        "group": "yapd",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "yapd:dev:web",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/web"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "."
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*(Ready in|Local:).*"
        }
      },
      "presentation": {
        "group": "yapd",
        "panel": "dedicated",
        "reveal": "always"
      }
    }
  ]
}
