generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum CertificateTrustMode {
  STRICT
  CUSTOM_CA
  ALLOW_SELF_SIGNED
}

enum AppLoginMode {
  PIHOLE_MASTER
  YAPD_PASSWORD
}

enum InstanceSessionAuthSource {
  HUMAN_MASTER
  STORED_SECRET
}

enum SyncOperationKey {
  BLOCKING
}

enum SyncJobStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILURE
}

enum SyncAttemptStatus {
  SUCCESS
  FAILURE
  NOOP
  SKIPPED
}

model AppConfig {
  id           String       @id @default("singleton")
  loginMode    AppLoginMode @default(PIHOLE_MASTER)
  passwordHash String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Instance {
  id               String                     @id @default(cuid())
  name             String
  baseUrl          String
  isBaseline       Boolean                    @default(false)
  syncEnabled      Boolean                    @default(true)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  lastValidatedAt  DateTime?
  lastKnownVersion String?
  secret           InstanceSecret?
  certificateTrust InstanceCertificateTrust?
  session          InstanceSession?
  syncAttempts     SyncAttempt[]
}

model InstanceSecret {
  id                String   @id @default(cuid())
  instanceId        String   @unique
  encryptedPassword String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  instance          Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model InstanceCertificateTrust {
  id                String               @id @default(cuid())
  instanceId        String               @unique
  mode              CertificateTrustMode @default(STRICT)
  certificatePem    String?
  fingerprintSha256 String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  instance          Instance             @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model InstanceSession {
  id               String                    @id @default(cuid())
  instanceId       String                    @unique
  encryptedSid     String
  encryptedCsrf    String
  piholeSessionId  Int?
  loginAt          DateTime?
  lastActiveAt     DateTime?
  validUntil       DateTime?
  authSource       InstanceSessionAuthSource
  lastErrorKind    String?
  lastErrorMessage String?
  lastErrorAt      DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  instance         Instance                  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  actorType  String
  actorLabel String?
  ipAddress  String?
  targetType String?
  targetId   String?
  result     String
  details    Json?
  createdAt  DateTime @default(now())
}

model SyncOperationPreset {
  id           String           @id @default(cuid())
  operationKey SyncOperationKey
  name         String           @default("Saved preset")
  timerSeconds Int
  sortOrder    Int              @default(1000)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([operationKey, sortOrder])
}

model SyncJob {
  id              String           @id @default(cuid())
  operationKey    SyncOperationKey
  scope           String
  requestedConfig Json
  status          SyncJobStatus
  summary         Json?
  startedAt       DateTime         @default(now())
  finishedAt      DateTime?
  attempts        SyncAttempt[]
}

model SyncAttempt {
  id             String            @id @default(cuid())
  syncJobId      String
  instanceId     String
  attemptNumber  Int
  status         SyncAttemptStatus
  message        String?
  requestPayload Json?
  responsePayload Json?
  createdAt      DateTime          @default(now())
  syncJob        SyncJob           @relation(fields: [syncJobId], references: [id], onDelete: Cascade)
  instance       Instance          @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([syncJobId, instanceId, attemptNumber])
}
